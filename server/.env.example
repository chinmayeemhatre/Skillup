# ── Server Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Local:   mongodb://localhost:27017/skillup
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/skillup
MONGO_URI=mongodb://localhost:27017/skillup

# JWT Secret Key — use a long, random string in production
JWT_SECRET=skillup_super_secret_jwt_key_change_this_in_production

# JWT Expiry — how long tokens stay valid
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# ── Optional: Email & OAuth (for future) ──────────────────────
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@email.com
# EMAIL_PASS=your_email_password
